{
  "name": "ProjectName",
  "version": "0.85.2",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "dev": "ENVFILE=.env.dev react-native run-android --mode devDebug --appId com.projectname.dev",
    "stag": "ENVFILE=.env.stag react-native run-android --mode stagDebug --appId com.projectname.stag",
    "prod": "ENVFILE=.env.prod react-native run-android --mode prodDebug --appId com.projectname",
    "devapk": "cd android && ENVFILE=.env.dev ./gradlew assembleDevRelease && open app/build/outputs/apk/dev/release",
    "stagapk": "cd android && ENVFILE=.env.stag ./gradlew assembleStagRelease && open app/build/outputs/apk/stag/release",
    "prodapk": "cd android && ENVFILE=.env.prod ./gradlew assembleProdRelease && open app/build/outputs/apk/prod/release",
    "devaab": "cd android && ENVFILE=.env.dev ./gradlew bundleDevRelease && open app/build/outputs/bundle/devRelease",
    "stagaab": "cd android && ENVFILE=.env.stag ./gradlew bundleStagRelease && open app/build/outputs/bundle/stagRelease",
    "prodaab": "cd android && ENVFILE=.env.prod ./gradlew bundleProdRelease && open app/build/outputs/bundle/prodRelease"
  },
  "dependencies": {
    "@react-native-community/hooks": "^100.1.0",
    "@react-native/new-app-screen": "0.85.2",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "i18next": "^25.8.7",
    "react": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-native": "0.85.2",
    "react-native-config": "^1.6.1",
    "react-native-mmkv": "^4.1.2",
    "react-native-nitro-modules": "^0.33.9",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-svg": "^15.15.4",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "redux-saga": "^1.4.2",
    "twrnc": "^4.16.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.3",
    "reactotron-react-native": "^5.1.18",
    "tailwindcss": "3.4.17",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
